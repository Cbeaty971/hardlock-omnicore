html, body {
  margin: 0;
  padding: 0;
  font-family: "Times New Roman", serif;
  background: #ffffff;
  color: #000000;
}

* {
  box-sizing: border-box;
  font-family: "Times New Roman", serif;
}

.app-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
}

.header {
  border-bottom: 1px solid #000;
  margin-bottom: 20px;
}

.chat-area {
  border: 1px solid #000;
  padding: 15px;
}

.chat-log {
  max-height: 400px;
  overflow-y: auto;
  margin-bottom: 15px;
}

.chat-input {
  display: flex;
  gap: 10px;
}

textarea {
  flex: 1;
  min-height: 60px;
  border: 1px solid #000;
  padding: 5px;
}

button {
  border: 1px solid #000;
  background: #f5f5f5;
  padding: 8px 16px;
  cursor: pointer;
}
